# ============================================================
# AgentCommerce Backend - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
ADMIN_SESSION_SECRET=REPLACE_WITH_ANOTHER_LONG_RANDOM_SECRET

# Encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_STRING

# Database
# Options: sqlite (default, for dev) | postgres (for production)
DB_TYPE=sqlite
# For postgres: postgres://user:password@host:5432/agentcommerce
DATABASE_URL=

# Email
# Options: smtp | sendgrid | postmark | ses
EMAIL_PROVIDER=smtp
FROM_EMAIL=noreply@agentcommerce.ai
ADMIN_EMAIL=team@agentcommerce.ai

# SMTP (Mailtrap for dev: https://mailtrap.io)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass

# SendGrid (set EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# Postmark (set EMAIL_PROVIDER=postmark)
POSTMARK_TOKEN=

# Amazon SES (set EMAIL_PROVIDER=ses)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
